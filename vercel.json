{
  "redirects": [
    { "source": "/blog/camasir-makinesi-sikmiyor", "destination": "/blog/camasir-makinesi-su-atmiyor/", "permanent": true },
    { "source": "/blog/camasir-makinesi-sikmiyor/", "destination": "/blog/camasir-makinesi-su-atmiyor/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/ariza",       "destination": "/index.html" },
    { "source": "/panel",       "destination": "/index.html" },
    { "source": "/panel/(.*)", "destination": "/index.html" },
    { "source": "/dpp/:seri_no", "destination": "/index.html" },
    { "source": "/ikinci-el",                     "destination": "/index.html" },
    { "source": "/ikinci-el/yeni",                "destination": "/index.html" },
    { "source": "/ikinci-el/admin",               "destination": "/index.html" },
    { "source": "/ikinci-el/alici/:token",        "destination": "/index.html" },
    { "source": "/ikinci-el/satis/:token",        "destination": "/index.html" },
    { "source": "/ikinci-el/:id",                 "destination": "/api/ilan/og?id=:id" },
    { "source": "/takip/:is_no",                  "destination": "/index.html" },
    { "source": "/servis-kayit",                  "destination": "/index.html" },
    { "source": "/servis-admin",                  "destination": "/index.html" },
    { "source": "/servis/:id",                    "destination": "/index.html" },
    { "source": "/urun/:id",                      "destination": "/index.html" },
    { "source": "/sepet",                         "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/expire", "schedule": "*/5 * * * *" }
  ]
}
